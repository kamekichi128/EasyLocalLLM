<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="Background" style="flex-grow: 1; background-color: rgb(255, 255, 255);">
        <ui:VisualElement style="flex-grow: 0; flex-direction: row; flex-shrink: 0;">
            <ui:Button text="Generate Puzzle" name="PuzzleGenerateButton" enabled="false" style="font-size: 32px; flex-grow: 1;" />
            <ui:Button text="Give Up" name="GiveupButton" enabled="false" style="flex-grow: 1; font-size: 32px;" />
        </ui:VisualElement>
        <ui:Label text="AI is initializaing..." name="PuzzleLabel" style="white-space: normal; font-size: 32px;" />
        <ui:Label text="Label" name="TruthLabel" style="display: none; white-space: normal; font-size: 32px;" />
        <ui:ScrollView style="flex-grow: 1; background-color: rgb(19, 19, 19); color: rgb(255, 255, 255);">
            <ui:Label name="ChatHistory" style="white-space: normal; font-size: 28px;" />
        </ui:ScrollView>
        <ui:VisualElement style="flex-grow: 0; flex-direction: row; flex-shrink: 0;">
            <ui:TextField label="Question" placeholder-text="Input your question" name="PlayerQuestionInput" multiline="true" style="flex-grow: 1; font-size: 28px; white-space: normal; flex-shrink: 1;" />
            <ui:Button text="Send" name="PlayerQuestionSendButton" />
        </ui:VisualElement>
        <ui:VisualElement style="flex-grow: 0; flex-direction: row; flex-shrink: 0;">
            <ui:TextField label="Truth" placeholder-text="Input truth" name="PlayerAnswerInput" multiline="true" style="flex-grow: 1; font-size: 28px; white-space: normal; flex-shrink: 1;" />
            <ui:Button text="Send" name="PlayerAnswerSendButton" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
